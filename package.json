{
  "name": "tlssa",
  "version": "0.1.1",
  "description": "A strictly typed Local and Storage Adapter for Typescript that uses JSON format when storing to actual storage.",
  "main": "dist/tlssa.umd.js",
  "module": "dist/tlssa.es.js",
  "types": "types/tlssa.d.ts",
  "exports": {
    ".": {
      "types": "./types/tlssa.d.ts",
      "import": "./dist/tlssa.es.js",
      "require": "./dist/tlssa.umd.js"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "src",
    "types",
    "LICENSE",
    "package-lock.json",
    "package.json",
    "README.md",
    "tsconfig.json",
    "vite.config.ts"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takawitter/tlssa.git"
  },
  "keywords": [
    "local-storage",
    "session-storage",
    "type-safe",
    "strictly-typed",
    "JSON",
    "browser",
    "typescript"
  ],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/takawitter/tlssa/issues"
  },
  "homepage": "https://github.com/takawitter/tlssa",
  "devDependencies": {
    "typescript": "~6.0.3",
    "vite": "^8.1.0"
  },
  "dependencies": {}
}
